{
  "expo": {
    "name": "DRONIEN",
    "slug": "dronien",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.juliansanchez.dronien"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#000000"
      },
      "package": "com.juliansanchez.dronien"
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      ["expo-av", { "microphonePermission": false }],
      "expo-screen-orientation",
      ["expo-location", {
        "locationAlwaysAndWhenInUsePermission": "Allow DRONIEN to use your location for flight conditions.",
        "locationWhenInUsePermission": "Allow DRONIEN to use your location for flight conditions."
      }]
    ]
  }
}
